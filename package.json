{
  "name": "jai-gurudev-frontend",
  "version": "2.1.0",
  "description": "Frontend for Jai Gurudev Spiritual Website - A comprehensive MERN stack application featuring a content management system, video transcripts, multi-language support, resource libraries for books and media, and a robust newsletter email system.",
  "author": "Antigravity",
  "private": true,
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.3.0",
    "bcryptjs": "^3.0.3",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "lru-cache": "^11.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.2",
    "react-scripts": "^5.0.1",
    "web-vitals": "^5.1.0"
  },
  "scripts": {
    "start": "node server/server.js",
    "start:client": "react-scripts start",
    "dev": "concurrently \"npm run start:client\" \"npm run server\"",
    "render-build": "npm install && cd server && npm install && cd .. && npm run build",
    "server": "cd server && node server.js",
    "prod": "npm run build && npm run server",
    "build": "react-scripts build",
    "postbuild": "react-snap || echo react-snap completed with warnings",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:5000",
  "devDependencies": {
    "@sentry/react": "^10.26.0",
    "@sentry/tracing": "^7.120.4",
    "concurrently": "^9.2.1",
    "react-axe": "^3.5.4",
    "react-snap": "^1.23.0",
    "webp-converter": "^2.3.3"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.6.0"
  },
  "keywords": [
    "spiritual",
    "react",
    "cms",
    "multilingual",
    "satvic",
    "recipes"
  ],
  "notes": {
    "backend_dependency": "Requires backend server running on port 5000",
    "transcript_system": "Uses direct YouTube Captions API (No external libraries/yt-dlp required)",
    "last_updated": "March 6, 2026"
  },
  "reactSnap": {
    "include": [
      "/",
      "/about",
      "/baba-jaigurudev",
      "/baba-umakant",
      "/glossary",
      "/prophecies",
      "/meditation",
      "/vegetarian-living",
      "/liberation",
      "/peace-and-society",
      "/satvic-lifestyle",
      "/prarthana",
      "/literature",
      "/gallery",
      "/downloads",
      "/virtual-tour",
      "/blog",
      "/announcements",
      "/contact"
    ],
    "skipThirdPartyRequests": true,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    }
  }
}